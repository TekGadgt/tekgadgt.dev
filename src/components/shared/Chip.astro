---
interface Props {
  label: string;
  variant?: 'default' | 'primary' | 'secondary' | 'tertiary' | 'success' | 'danger';
}

const { label, variant = 'default' } = Astro.props;
---

<span class:list={['chip', `chip--${variant}`]}>{label}</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 1.7rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 900;
    padding: 0.32rem 0.62rem;
    border: 2px solid var(--chip-border);
    background: var(--chip-bg);
    color: var(--chip-fg);
    line-height: 1;
    white-space: nowrap;
    box-shadow: 2px 2px 0 var(--chip-border);
  }

  .chip--primary {
    background: var(--chip-featured-bg);
    color: var(--chip-featured-fg);
    border-color: var(--border-on-accent);
    box-shadow: 2px 2px 0 var(--border-on-accent);
  }

  .chip--secondary {
    background: var(--accent-secondary);
    color: var(--chip-featured-fg);
    border-color: var(--border-on-accent);
    box-shadow: 2px 2px 0 var(--border-on-accent);
  }

  .chip--tertiary {
    background: var(--accent-tertiary);
    color: var(--chip-featured-fg);
    border-color: var(--border-on-accent);
    box-shadow: 2px 2px 0 var(--border-on-accent);
  }

  .chip--success {
    background: var(--chip-active-bg);
    color: var(--chip-active-fg);
    border-color: var(--border-on-accent);
    box-shadow: 2px 2px 0 var(--border-on-accent);
  }

  .chip--danger {
    background: var(--chip-danger-bg);
    color: var(--chip-danger-fg);
    border-color: var(--border-on-accent);
    box-shadow: 2px 2px 0 var(--border-on-accent);
  }
</style>
