---
import Chip from '../shared/Chip.astro';
import { reader } from '../../lib/reader';
const appearances = await reader.singletons.appearances.read();
const items = appearances?.items ?? [];

type AppearanceType = 'talk' | 'interview' | 'podcast' | 'article';

const variantMap: Record<AppearanceType, 'primary' | 'secondary' | 'tertiary' | 'default'> = {
  talk: 'primary',
  interview: 'secondary',
  podcast: 'tertiary',
  article: 'default',
};

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return '';
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(dateStr));
}
---

{items.length > 0 && (
  <section class="appearances">
    <h2 class="appearances__heading">Appearances</h2>
    <ul class="appearances__list">
      {items.map(item => (
        <li class="appearance-item">
          <div class="appearance-item__meta">
            <Chip
              label={item.type}
              variant={variantMap[item.type as AppearanceType] ?? 'default'}
            />
            {item.date && (
              <time class="appearance-item__date" datetime={item.date}>
                {formatDate(item.date)}
              </time>
            )}
          </div>
          <div class="appearance-item__body">
            {item.url ? (
              <a
                href={item.url}
                class="appearance-item__title"
                target="_blank"
                rel="noopener noreferrer"
              >
                {item.title}
                <span class="appearance-item__external" aria-hidden="true">&#8599;</span>
              </a>
            ) : (
              <span class="appearance-item__title appearance-item__title--no-link">
                {item.title}
              </span>
            )}
            {item.outlet && (
              <span class="appearance-item__outlet">{item.outlet}</span>
            )}
          </div>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .appearances {
    margin-top: 3rem;
  }

  .appearances__heading {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: var(--border-width) solid var(--border);
  }

  .appearances__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .appearance-item {
    border: var(--border-width) solid var(--border);
    border-top: none;
    padding: var(--row-pad-y) var(--row-pad-x);
    background: linear-gradient(180deg, var(--surface-elevated, var(--surface)) 0%, var(--surface) 100%);
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 0.75rem;
    transition: background-color 0.1s;
  }

  .appearances__list .appearance-item:first-child {
    border-top: var(--border-width) solid var(--border);
  }

  .appearance-item:hover {
    background-color: var(--muted);
  }

  .appearance-item__meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.375rem;
    flex-shrink: 0;
    min-width: 100px;
  }

  .appearance-item__date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: var(--text);
    opacity: 0.65;
    white-space: nowrap;
  }

  .appearance-item__body {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
  }

  .appearance-item__title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }

  a.appearance-item__title:hover {
    color: var(--link-hover);
    text-decoration: underline;
    text-decoration-thickness: 2px;
  }

  .appearance-item__external {
    font-size: 0.875rem;
    opacity: 0.5;
    margin-left: 0.125rem;
  }

  .appearance-item__outlet {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.6;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .appearance-item__meta { min-width: 0; }
    .appearance-item__date, .appearance-item__outlet { white-space: normal; overflow-wrap: anywhere; }
  }

  @media (max-width: 500px) {
    .appearance-item {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
