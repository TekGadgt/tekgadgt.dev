---
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const homepage = await reader.singletons.homepage.read();
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="hero-heading">{homepage?.heroHeading}</h1>
        <p class="hero-tagline">{homepage?.tagline}</p>
        <p class="hero-bio">{homepage?.bioText}</p>

        <div class="hero-ctas">
          {homepage?.primaryCtaLabel && homepage?.primaryCtaUrl && (
            <a href={homepage.primaryCtaUrl} class="btn btn--primary">
              {homepage.primaryCtaLabel}
            </a>
          )}
          {homepage?.secondaryCtaLabel && homepage?.secondaryCtaUrl && (
            <a href={homepage.secondaryCtaUrl} class="btn btn--secondary">
              {homepage.secondaryCtaLabel}
            </a>
          )}
          <a href="/about" class="hero-read-more">
            Read full story &rarr;
          </a>
        </div>
      </div>

      {homepage?.heroImage && (
        <div class="hero-photo">
          <img src={homepage.heroImage} alt={homepage?.heroHeading || 'Photo'} />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .hero {
    border-bottom: var(--border-width) solid var(--border);
    background-color: var(--bg);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
  }

  .hero-content {
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
  }

  .hero-photo {
    flex-shrink: 0;
    width: 280px;
    height: 280px;
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
    }

    .hero-photo {
      width: 200px;
      height: 200px;
    }

    .hero-ctas {
      justify-content: center;
    }
  }

  .hero-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: var(--line-height-heading);
    color: var(--text);
    margin: 0 0 0.5rem;
    letter-spacing: -0.03em;
  }

  .hero-tagline {
    font-family: var(--font-retro);
    font-size: clamp(0.875rem, 2vw, 1rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    margin: 0 0 1.5rem;
    opacity: 0.75;
  }

  .hero-bio {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: var(--line-height-body);
    color: var(--text);
    max-width: 60ch;
    margin: 0 0 2.5rem;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  /* Neobrutalist button */
  .btn {
    display: inline-block;
    font-family: var(--font-retro);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: bold;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    transition: transform 0.1s, box-shadow 0.1s;
    cursor: pointer;
  }

  .btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-hover);
  }

  .btn:active {
    transform: translate(2px, 2px);
    box-shadow: none;
  }

  .btn:focus-visible {
    outline: var(--border-width) solid var(--accent-secondary);
    outline-offset: 2px;
  }

  .btn--primary {
    background-color: var(--accent-primary);
    color: var(--text);
  }

  .btn--secondary {
    background-color: var(--accent-secondary);
    color: var(--text);
  }

  .hero-read-more {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 2px;
  }

  .hero-read-more:hover {
    color: var(--accent-secondary);
  }

  .hero-read-more:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }
</style>
