---
import Chip from '../shared/Chip.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  tags?: string[];
  slug: string;
  image?: string | null;
}

const { title, description, date, tags = [], slug, image } = Astro.props;

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
}).format(new Date(date));
---

<a href={`/blog/${slug}`} class="post-card">
  {image && (
    <div class="post-card__image">
      <img src={image} alt={title} loading="lazy" />
    </div>
  )}
  <div class="post-card__body">
    <time class="post-card__date" datetime={date}>{formatted}</time>
    <h2 class="post-card__title">{title}</h2>
    <p class="post-card__description">{description}</p>
    {tags.length > 0 && (
      <div class="post-card__tags">
        {tags.map(tag => <Chip label={tag} />)}
      </div>
    )}
  </div>
  <span class="post-card__arrow" aria-hidden="true">&#8594;</span>
</a>

<style>
  .post-card {
    position: relative;
    display: block;
    background: linear-gradient(180deg, var(--surface-elevated, var(--surface)) 0%, var(--surface) 100%);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    text-decoration: none;
    color: var(--text);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .post-card:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hover);
  }

  .post-card:active {
    transform: translate(var(--shadow-offset), var(--shadow-offset));
    box-shadow: none;
  }

  .post-card:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }

  .post-card__image {
    border-bottom: var(--border-width) solid var(--border);
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .post-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .post-card__body {
    padding: 1.25rem 1.25rem 2rem;
  }

  .post-card__date {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--text);
    opacity: 0.6;
    margin-bottom: 0.5rem;
  }

  .post-card__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    line-height: 1.1;
    margin: 0 0 0.625rem;
    color: var(--text);
  }

  .post-card__description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.8;
    margin: 0 0 0.875rem;
  }

  .post-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-card::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 0 3rem 3rem;
    border-color: transparent transparent #1a5fd4 transparent;
    pointer-events: none;
  }

  .post-card:visited::after {
    border-color: transparent transparent #7B2D8E transparent;
  }

  .post-card__arrow {
    position: absolute;
    bottom: 0.35rem;
    right: 0.3rem;
    font-size: 1.3rem;
    font-weight: bold;
    color: #fff;
    opacity: 1;
    z-index: 1;
    line-height: 1;
  }
</style>
