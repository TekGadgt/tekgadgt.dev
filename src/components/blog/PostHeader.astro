---
import Chip from '../shared/Chip.astro';

interface Props {
  title: string;
  date: string;
  tags?: string[];
  image?: string | null;
  description?: string;
}

const { title, date, tags = [], image, description } = Astro.props;

const formatted = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
}).format(new Date(date));
---

<header class="post-header">
  <div class="post-header__inner">
    <div class="post-header__meta">
      <time class="post-header__date" datetime={date}>{formatted}</time>
      {tags.length > 0 && (
        <div class="post-header__tags">
          {tags.map(tag => <Chip label={tag} variant="primary" />)}
        </div>
      )}
    </div>
    <h1 class="post-header__title">{title}</h1>
    {description && (
      <p class="post-header__description">{description}</p>
    )}
  </div>
  {image && (
    <div class="post-header__image">
      <img src={image} alt={title} />
    </div>
  )}
</header>

<style>
  .post-header {
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    background-color: var(--surface);
    margin-bottom: 2.5rem;
  }

  .post-header__inner {
    padding: 2rem 2rem 1.5rem;
  }

  .post-header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .post-header__date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--text);
    opacity: 0.6;
    text-transform: uppercase;
  }

  .post-header__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-header__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.05;
    margin: 0 0 0.75rem;
    color: var(--text);
  }

  .post-header__description {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.75;
    margin: 0;
  }

  .post-header__image {
    border-top: var(--border-width) solid var(--border);
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .post-header__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
