---
import { reader } from '../../lib/reader';
import ButtonWall from '../shared/ButtonWall.astro';
const footer = await reader.singletons.footer.read();
---

<footer class="site-footer" id="footer">
  <div class="footer-inner">
    <ButtonWall />

    <div class="footer-content">
      <div class="footer-contact">
        {footer?.email && (
          <a href={`mailto:${footer.email}`} class="footer-link footer-email">
            {footer.email}
          </a>
        )}
        {footer?.calUrl && (
          <a href={footer.calUrl} class="footer-link footer-cal" target="_blank" rel="noopener noreferrer">
            Book a call
          </a>
        )}
      </div>

      <nav class="footer-social" aria-label="Social links">
        {footer?.socialLinks?.map(link => (
          <a
            href={link.url}
            class:list={['footer-link', 'footer-social-link', { 'footer-social-icon-link': !!link.icon }]}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={link.icon ? link.platform : undefined}
          >
            {link.icon ? (
              <span
                class="social-icon"
                style={`--icon-url: url(https://api.iconify.design/${link.icon.includes(':') ? link.icon.replace(':', '/') : `simple-icons/${link.icon}`}.svg)`}
                aria-hidden="true"
              />
            ) : (
              link.platform
            )}
          </a>
        ))}
      </nav>
    </div>

    <p class="footer-copy">
      &copy; {new Date().getFullYear()} Ryan McGovern
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border-width) solid var(--border);
    background-color: var(--surface);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .footer-content {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .footer-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-left: auto;
  }

  .footer-link {
    display: inline-block;
    font-family: var(--font-retro);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: var(--border-width) solid var(--border);
    padding: 0.375rem 0.75rem;
    box-shadow: var(--shadow);
    transition: background-color 0.1s, box-shadow 0.1s, transform 0.1s;
  }

  .footer-link:hover {
    background-color: var(--accent-primary);
    color: var(--text-on-accent);
    box-shadow: var(--shadow-hover);
    transform: translate(2px, 2px);
  }

  .footer-link:active {
    transform: translate(var(--shadow-offset), var(--shadow-offset));
    box-shadow: none;
  }

  .footer-link:focus-visible {
    outline: var(--border-width) solid var(--accent-secondary);
    outline-offset: 2px;
  }

  .footer-social-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
  }

  .social-icon {
    display: block;
    width: 1.25rem;
    height: 1.25rem;
    background-color: currentColor;
    -webkit-mask-image: var(--icon-url);
    mask-image: var(--icon-url);
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.6;
    margin: 0;
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
    }

    .footer-social {
      margin-left: 0;
    }
  }

</style>
