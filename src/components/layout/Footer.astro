---
import { reader } from '../../lib/reader';
import ButtonWall from '../shared/ButtonWall.astro';
const footer = await reader.singletons.footer.read();
---

<footer class="site-footer" id="footer">
  <div class="footer-inner">
    <ButtonWall />

    <div class="footer-content">
      <div class="footer-contact" id="contact">
        {footer?.email && (
          <a href={`mailto:${footer.email}`} class="footer-link footer-email">
            {footer.email}
          </a>
        )}
        {footer?.calUrl && (
          <a href={footer.calUrl} class="footer-link footer-cal" target="_blank" rel="noopener noreferrer">
            Book a call
          </a>
        )}
      </div>

      <nav class="footer-social" aria-label="Social links">
        {footer?.socialLinks?.map(link => (
          <a
            href={link.url}
            class="footer-link footer-social-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.platform}
          </a>
        ))}
      </nav>
    </div>

    <p class="footer-copy">
      &copy; {new Date().getFullYear()} Ryan McGovern
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border-width) solid var(--border);
    background-color: var(--surface);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .footer-content {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .footer-contact {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-left: auto;
  }

  .footer-link {
    display: inline-block;
    font-family: var(--font-retro);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: var(--border-width) solid var(--border);
    padding: 0.375rem 0.75rem;
    box-shadow: var(--shadow);
    transition: background-color 0.1s, box-shadow 0.1s, transform 0.1s;
  }

  .footer-link:hover {
    background-color: var(--accent-primary);
    color: var(--text-on-accent);
    box-shadow: var(--shadow-hover);
    transform: translate(2px, 2px);
  }

  .footer-link:active {
    transform: translate(var(--shadow-offset), var(--shadow-offset));
    box-shadow: none;
  }

  .footer-link:focus-visible {
    outline: var(--border-width) solid var(--accent-secondary);
    outline-offset: 2px;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.6;
    margin: 0;
  }

  @media (max-width: 600px) {
    .footer-content {
      flex-direction: column;
    }

    .footer-social {
      margin-left: 0;
    }
  }

  @keyframes link-pulse {
    0%, 40% {
      background-color: var(--accent-primary);
      color: var(--text-on-accent);
      transform: translate(-1px, -1px);
      box-shadow: var(--shadow);
    }
    100% {
      background-color: transparent;
      color: var(--text);
      transform: translate(0, 0);
    }
  }

  .footer-link.highlight {
    animation: link-pulse 800ms ease-out 1;
  }
</style>

<script>
  let pending = false;

  function highlightContact() {
    if (pending) return;
    pending = true;
    const links = document.querySelectorAll('#contact .footer-link');
    links.forEach(link => {
      link.classList.remove('highlight');
      void (link as HTMLElement).offsetWidth;
      link.classList.add('highlight');
      link.addEventListener('animationend', () => {
        link.classList.remove('highlight');
        pending = false;
      }, { once: true });
    });
  }

  document.querySelectorAll('a[href="#footer"], a[href="#contact"]').forEach(link => {
    link.addEventListener('click', () => {
      setTimeout(highlightContact, 600);
    });
  });

  if (window.location.hash === '#footer' || window.location.hash === '#contact') {
    highlightContact();
  }
</script>
