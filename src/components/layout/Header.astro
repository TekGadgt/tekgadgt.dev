---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { label: 'Work', href: '/work' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
  { label: 'Now', href: '/now' },
  { label: 'Uses', href: '/uses' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-name">Ryan McGovern</a>

    <button class="nav-hamburger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="main-nav">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>

    <nav id="main-nav" class="main-nav" aria-label="Main navigation">
      <ul class="nav-list">
        {navLinks.map(link => (
          <li class="nav-item">
            <a
              href={link.href}
              class:list={['nav-link', { 'nav-link--active': isActive(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-toggle">
      <ThemeToggle />
    </div>
  </div>
</header>

<script>
  const hamburger = document.querySelector('.nav-hamburger') as HTMLButtonElement | null;
  const nav = document.querySelector('#main-nav') as HTMLElement | null;

  if (hamburger && nav) {
    hamburger.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('main-nav--open');
      hamburger.setAttribute('aria-expanded', String(isOpen));
    });
  }
</script>

<style>
  .site-header {
    background-color: var(--surface);
    border-bottom: var(--border-width) solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 4rem;
  }

  .site-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: -0.02em;
  }

  .site-name:hover {
    color: var(--link-hover);
  }

  .site-name:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }

  /* Nav */
  .main-nav {
    flex: 1;
  }

  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
  }

  .nav-link {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    font-family: var(--font-retro);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: var(--border-width) solid transparent;
    transition: background-color 0.1s, color 0.1s, border-color 0.1s, box-shadow 0.1s;
  }

  .nav-link:hover:not(.nav-link--active) {
    background-color: var(--muted);
    border-color: var(--border);
  }

  .nav-link--active {
    background-color: var(--accent-primary);
    border-color: var(--border-on-accent);
    color: var(--text-on-accent);
    font-weight: bold;
    box-shadow: 2px 2px 0 var(--border-on-accent);
  }

  .nav-link:focus-visible {
    outline: var(--border-width) solid var(--accent-secondary);
    outline-offset: 2px;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: var(--border-width) solid var(--border);
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .nav-hamburger:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }

  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--text);
  }

  .header-toggle {
    flex-shrink: 0;
    margin-left: auto;
  }

  /* Mobile nav */
  @media (max-width: 768px) {
    .nav-hamburger {
      display: flex;
    }

    .header-toggle {
      margin-left: 0;
    }

    .main-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--surface);
      border-bottom: var(--border-width) solid var(--border);
      padding: 0.75rem 0;
    }

    .main-nav--open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      gap: 0;
    }

    .nav-link {
      display: block;
      padding: 0.75rem 1.5rem;
      border: none;
      border-bottom: 1px solid var(--muted);
    }

    .nav-link--active {
      border: none;
      box-shadow: none;
      border-left: 4px solid var(--border-on-accent);
    }

    .header-inner {
      flex-wrap: wrap;
      gap: 0.75rem;
      height: auto;
      min-height: 4rem;
      padding-top: 0.5rem;
      padding-bottom: 0.5rem;
    }
  }

  @media (max-width: 420px) {
    .header-inner {
      padding-inline: 1rem;
      gap: 0.5rem;
    }

    .site-name {
      font-size: 1rem;
    }
  }
</style>
