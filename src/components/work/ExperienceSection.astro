---
import Chip from '../shared/Chip.astro';
import { reader } from '../../lib/reader';
const experience = await reader.singletons.experience.read();

const items = experience?.items ?? [];
if (items.length === 0) return;

function formatDate(dateStr: string | null | undefined): string {
  if (!dateStr) return 'Present';
  const date = new Date(dateStr + 'T00:00:00');
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<section class="experience-section">
  <div class="timeline">
    {items.map(item => (
      <article class="timeline-entry">
        <div class="timeline-header">
          <div class="timeline-title-group">
            <h3 class="timeline-role">{item.role}</h3>
            <div class="timeline-meta">
              {item.url ? (
                <a href={item.url} class="timeline-company timeline-company--link" target="_blank" rel="noopener noreferrer">
                  {item.company}
                </a>
              ) : (
                <span class="timeline-company">{item.company}</span>
              )}
              {item.location && <span class="timeline-location">{item.location}</span>}
              {item.employmentType && <span class="timeline-type">{item.employmentType}</span>}
            </div>
          </div>
          <span class="timeline-dates">
            {formatDate(item.startDate)} – {formatDate(item.endDate)}
          </span>
        </div>

        {item.summary && (
          <p class="timeline-summary">{item.summary}</p>
        )}

        {item.impact && item.impact.length > 0 && (
          <ul class="timeline-impact">
            {item.impact.map(point => (
              <li class="timeline-impact-item">{point}</li>
            ))}
          </ul>
        )}

        {item.tech && item.tech.length > 0 && (
          <div class="timeline-tech">
            {item.tech.map(t => <Chip label={t} />)}
          </div>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .experience-section {
    margin-bottom: 3rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-entry {
    border: var(--border-width) solid var(--border);
    border-top: none;
    padding: var(--row-pad-y) var(--row-pad-x);
    background: linear-gradient(180deg, var(--surface-elevated, var(--surface)) 0%, var(--surface) 100%);
  }

  .timeline-entry:first-child {
    border-top: var(--border-width) solid var(--border);
  }

  .timeline-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .timeline-role {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    margin: 0 0 0.25rem;
  }

  .timeline-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .timeline-company {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.85;
  }

  .timeline-company--link {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .timeline-company--link:hover {
    color: var(--link-hover);
  }

  .timeline-location,
  .timeline-type {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text);
    opacity: 0.65;
  }

  .timeline-location::before,
  .timeline-type::before {
    content: '·';
    margin-right: 0.5rem;
  }

  .timeline-dates {
    font-family: var(--font-retro);
    font-size: 0.6875rem;
    letter-spacing: 0.05em;
    color: var(--text);
    opacity: 0.65;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .timeline-summary {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.9;
    margin: 0 0 0.875rem;
  }

  .timeline-impact {
    list-style: none;
    margin: 0 0 0.875rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .timeline-impact-item {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-height-body);
    color: var(--text);
    padding-left: 1.25rem;
    position: relative;
  }

  .timeline-impact-item::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--accent-primary);
    font-size: 0.875rem;
  }

  .timeline-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }
</style>
