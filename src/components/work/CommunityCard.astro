---
import Chip from '../shared/Chip.astro';

interface Props {
  orgName: string;
  role?: string | null;
  description?: string | null;
  url?: string | null;
  status?: 'active' | 'past';
  featured?: boolean;
}

const { orgName, role, description, url, status = 'active', featured = false } = Astro.props;

const CardTag = url ? 'a' : 'div';
const cardProps = url
  ? { href: url, target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<CardTag class:list={['community-card', { 'community-card--featured': featured }]} {...cardProps}>
  {featured && <span class="featured-label">FEATURED</span>}
  <div class="card-header">
    <div>
      <h3 class="card-org">{orgName}</h3>
      {role && <p class="card-role">{role}</p>}
    </div>
    <Chip
      label={status.toUpperCase()}
      variant={status === 'active' ? 'success' : 'default'}
    />
  </div>
  {description && <p class="card-description">{description}</p>}
  {url && <span class="card-external-hint" aria-hidden="true">&#8599;</span>}
</CardTag>

<style>
  .community-card {
    position: relative;
    display: block;
    background: linear-gradient(180deg, var(--surface-elevated, var(--surface)) 0%, var(--surface) 100%);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.1s, box-shadow 0.1s;
    overflow: visible;
  }

  a.community-card:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hover);
  }

  a.community-card:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }

  .featured-label {
    position: absolute;
    top: 0;
    right: 12px;
    transform: translateY(-55%);
    z-index: 3;
    pointer-events: none;
    font-family: var(--font-retro);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    background: var(--chip-featured-bg);
    color: var(--chip-featured-fg);
    border: 2px solid var(--chip-border);
    padding: 0.32rem 0.62rem;
    box-shadow: 2px 2px 0 var(--chip-border);
    outline: 3px solid var(--bg);
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.625rem;
  }

  .card-org {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    line-height: 1.2;
    margin: 0 0 0.25rem;
    color: var(--text);
  }

  .card-role {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--text);
    opacity: 0.75;
    margin: 0;
    text-transform: uppercase;
  }

  .card-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.85;
    margin: 0;
  }

  .card-external-hint {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    font-size: 1rem;
    opacity: 0.4;
  }
</style>
