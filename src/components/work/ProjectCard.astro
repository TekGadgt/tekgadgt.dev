---
import Chip from '../shared/Chip.astro';

interface Props {
  name: string;
  description?: string | null;
  url?: string | null;
  techTags?: string[];
  image?: string | null;
  featured?: boolean;
}

const { name, description, url, techTags = [], image, featured = false } = Astro.props;

const CardTag = url ? 'a' : 'div';
const cardProps = url
  ? { href: url, target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<CardTag class:list={['project-card', { 'project-card--featured': featured }]} {...cardProps}>
  {featured && <span class="featured-label">FEATURED</span>}
  {image && (
    <div class="card-image">
      <img src={image} alt={name} loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    {description && <p class="card-description">{description}</p>}
    {techTags.length > 0 && (
      <div class="card-tags">
        {techTags.map(tag => <Chip label={tag} />)}
      </div>
    )}
  </div>
  {url && <svg class="card-external-hint" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>}
</CardTag>

<style>
  .project-card {
    position: relative;
    display: block;
    background: linear-gradient(180deg, var(--surface-elevated, var(--surface)) 0%, var(--surface) 100%);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.1s, box-shadow 0.1s;
    overflow: visible;
  }

  a.project-card:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-hover);
  }

  a.project-card:active {
    transform: translate(var(--shadow-offset), var(--shadow-offset));
    box-shadow: none;
  }

  a.project-card:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }

  .featured-label {
    position: absolute;
    top: 0;
    right: 12px;
    transform: translateY(-55%);
    z-index: 3;
    pointer-events: none;
    font-family: var(--font-retro);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    background: var(--chip-featured-bg);
    color: var(--chip-featured-fg);
    border: 2px solid var(--border-on-accent);
    padding: 0.32rem 0.62rem;
    box-shadow: 2px 2px 0 var(--border-on-accent);
    outline: 3px solid var(--bg);
  }

  .card-image {
    margin-bottom: 1rem;
    border: var(--border-width) solid var(--border);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .card-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.85;
    margin: 0 0 0.875rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  a.project-card::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 0 3rem 3rem;
    border-color: transparent transparent #1a5fd4 transparent;
    pointer-events: none;
  }

  a.project-card:visited::after {
    border-color: transparent transparent #7B2D8E transparent;
  }

  .card-external-hint {
    position: absolute;
    bottom: 0.45rem;
    right: 0.4rem;
    color: #fff;
    z-index: 1;
  }
</style>
