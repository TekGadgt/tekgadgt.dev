---
import Chip from '../shared/Chip.astro';

interface Props {
  name: string;
  description?: string | null;
  url?: string | null;
  techTags?: string[];
  image?: string | null;
  featured?: boolean;
}

const { name, description, url, techTags = [], image, featured = false } = Astro.props;

const CardTag = url ? 'a' : 'div';
const cardProps = url
  ? { href: url, target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<CardTag class:list={['project-card', { 'project-card--featured': featured }]} {...cardProps}>
  {featured && <span class="featured-label">FEATURED</span>}
  {image && (
    <div class="card-image">
      <img src={image} alt={name} loading="lazy" />
    </div>
  )}
  <div class="card-body">
    <h3 class="card-name">{name}</h3>
    {description && <p class="card-description">{description}</p>}
    {techTags.length > 0 && (
      <div class="card-tags">
        {techTags.map(tag => <Chip label={tag} />)}
      </div>
    )}
  </div>
  {url && <span class="card-external-hint" aria-hidden="true">&#8599;</span>}
</CardTag>

<style>
  .project-card {
    position: relative;
    display: block;
    background-color: var(--surface);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  a.project-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-hover);
  }

  a.project-card:focus-visible {
    outline: var(--border-width) solid var(--accent-primary);
    outline-offset: 2px;
  }

  .project-card--featured {
    border-color: var(--accent-primary);
  }

  .featured-label {
    position: absolute;
    top: 0;
    right: 0;
    font-family: var(--font-retro);
    font-size: 0.5625rem;
    letter-spacing: 0.08em;
    background-color: var(--accent-primary);
    color: var(--text);
    border-left: var(--border-width) solid var(--border);
    border-bottom: var(--border-width) solid var(--border);
    padding: 0.2rem 0.5rem;
  }

  .card-image {
    margin-bottom: 1rem;
    border: var(--border-width) solid var(--border);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .card-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.85;
    margin: 0 0 0.875rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .card-external-hint {
    position: absolute;
    bottom: 0.75rem;
    right: 0.75rem;
    font-size: 1rem;
    opacity: 0.4;
  }
</style>
