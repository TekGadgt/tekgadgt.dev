---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Ryan McGovern"
  description="This page doesn't exist."
>
  <main class="not-found">
    <div class="not-found__inner">
      <div class="not-found__card">
        <div class="not-found__stamp">404</div>
        <h1 class="not-found__heading">Page Not Found</h1>
        <p class="not-found__message">
          You've ventured into the void. Nothing lives here — yet.
        </p>
        <a href="/" class="not-found__home">Back to Home</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    padding: 4rem 1.5rem 6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
  }

  .not-found__inner {
    max-width: 520px;
    width: 100%;
    margin: 0 auto;
  }

  .not-found__card {
    background-color: var(--surface);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow-hover);
    padding: 2.5rem 2rem;
    text-align: center;
  }

  .not-found__stamp {
    font-family: var(--font-heading);
    font-size: clamp(5rem, 20vw, 9rem);
    line-height: 1;
    color: var(--accent-primary);
    -webkit-text-stroke: var(--border-width) var(--border);
    letter-spacing: -0.04em;
    margin-bottom: 0.25rem;
  }

  .not-found__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .not-found__message {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: var(--line-height-body);
    color: var(--text);
    opacity: 0.7;
    margin: 0 0 1.75rem;
  }

  .not-found__home {
    display: inline-block;
    font-family: var(--font-retro);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
    border: var(--border-width) solid var(--border);
    padding: 0.625rem 1.25rem;
    background-color: var(--accent-primary);
    box-shadow: var(--shadow);
    transition: transform 0.1s, box-shadow 0.1s;
  }

  .not-found__home:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-hover);
  }

  .not-found__home:focus-visible {
    outline: var(--border-width) solid var(--accent-secondary);
    outline-offset: 2px;
  }
</style>
