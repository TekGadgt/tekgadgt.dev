---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostHeader from '../../components/blog/PostHeader.astro';
import { reader } from '../../lib/reader';
import Markdoc from '@markdoc/markdoc';
import '../../styles/prose.css';

export async function getStaticPaths() {
  let posts = await reader.collections.posts.all();

  if (import.meta.env.PROD) {
    posts = posts.filter(p => !p.entry.draft);
  }

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }));
}

const { slug } = Astro.props as { slug: string };
const post = await reader.collections.posts.read(slug);

if (!post) {
  return Astro.redirect('/404');
}

// Render markdoc content: content field is a ContentFormField, so ValueForReading is () => Promise<{ node }>
const contentResult = await post.content();
const renderable = Markdoc.transform(contentResult.node);
const contentHtml = Markdoc.renderers.html(renderable);
---

<BaseLayout title={`${post.title} — Ryan McGovern`} description={post.description}>
  <div class="post-page">
    <div class="post-inner">
      <PostHeader
        title={post.title}
        date={post.date ?? ''}
        tags={post.tags as string[]}
        image={post.image ?? null}
        description={post.description}
      />
      <article class="prose" set:html={contentHtml} />
    </div>
  </div>
</BaseLayout>

<style>
  .post-page {
    padding: 3rem 1.5rem 4rem;
  }

  .post-inner {
    max-width: var(--prose-width);
    margin: 0 auto;
  }


</style>
