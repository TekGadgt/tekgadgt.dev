---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import Markdoc from '@markdoc/markdoc';

const reader = createReader(process.cwd(), keystaticConfig);
const now = await reader.singletons.now.read();

const contentResult = now?.content ? await now.content() : null;
const contentHtml = contentResult
  ? Markdoc.renderers.html(Markdoc.transform(contentResult.node))
  : '';

const updatedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
}).format(new Date());
---

<BaseLayout
  title="Now — Ryan McGovern"
  description="What Ryan McGovern is currently focused on."
>
  <main class="now-page">
    <div class="now-inner">
      <header class="now-header">
        <h1 class="now-heading">Now</h1>
        <p class="now-updated">
          Last updated: <time>{updatedDate}</time>
        </p>
        <p class="now-about">
          A <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now page</a> is a snapshot of what I'm currently up to.
        </p>
      </header>

      {contentHtml ? (
        <article class="prose" set:html={contentHtml} />
      ) : (
        <p class="now-empty">No content yet.</p>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .now-page {
    padding: 3rem 1.5rem 4rem;
  }

  .now-inner {
    max-width: var(--prose-width);
    margin: 0 auto;
  }

  .now-header {
    margin-bottom: 2rem;
    border-bottom: var(--border-width) solid var(--border);
    padding-bottom: 1.25rem;
  }

  .now-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .now-updated {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--text);
    opacity: 0.55;
    margin: 0 0 0.5rem;
    text-transform: uppercase;
  }

  .now-about {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text);
    opacity: 0.65;
    margin: 0;
  }

  .now-empty {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    color: var(--text);
    opacity: 0.6;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-family: var(--font-heading);
    line-height: var(--line-height-heading);
    margin: 1.75em 0 0.6em;
    color: var(--text);
  }

  .prose :global(h2) { font-size: 1.6rem; }
  .prose :global(h3) { font-size: 1.3rem; }

  .prose :global(p) {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: var(--line-height-body);
    color: var(--text);
    margin: 0 0 1.25em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25em 1.5rem;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: var(--line-height-body);
  }

  .prose :global(li) {
    margin-bottom: 0.375em;
  }

  .prose :global(a) {
    color: var(--accent-secondary);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--accent-primary);
  }

  .prose :global(blockquote) {
    margin: 1.5em 0;
    padding: 0.75em 1.25em;
    background-color: var(--surface);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--muted);
    padding: 0.15em 0.4em;
  }

  .prose :global(hr) {
    border: none;
    border-top: var(--border-width) solid var(--border);
    margin: 2.5em 0;
  }
</style>
