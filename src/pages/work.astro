---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ExperienceSection from '../components/work/ExperienceSection.astro';
import ProjectCard from '../components/work/ProjectCard.astro';
import CommunityCard from '../components/work/CommunityCard.astro';
import ButtonWall from '../components/shared/ButtonWall.astro';
import { reader } from '../lib/reader';
const projects = await reader.singletons.projects.read();
const community = await reader.singletons.community.read();
---

<BaseLayout title="Work — Ryan McGovern" description="Projects, community work, and professional experience.">
  <div class="work-page">
    <div class="page-inner">
      <div class="page-header">
        <h1 class="page-title">Work</h1>
      </div>
      <ExperienceSection />

      <div class="work-grid">
        <section class="projects">
          <h2 class="section-heading">Projects</h2>
          <div class="cards-list">
            {projects?.items.map(project => <ProjectCard {...project} />)}
          </div>
        </section>

        <section class="community">
          <h2 class="section-heading">Community</h2>
          <div class="cards-list">
            {community?.items.map(role => <CommunityCard {...role} />)}
          </div>
        </section>
      </div>

      <ButtonWall />
    </div>
  </div>
</BaseLayout>

<style>
  .work-page {
    padding: 3rem 1.5rem 4rem;
  }

  .page-inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .page-header {
    padding-bottom: 2rem;
    border-bottom: var(--border-width) solid var(--border-divider);
    margin-bottom: 2.5rem;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: var(--line-height-heading);
    letter-spacing: -0.03em;
    margin: 0;
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .section-heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: var(--border-width) solid var(--border-divider);
  }

  .cards-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (max-width: 768px) {
    .work-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
