---
import BaseLayout from '../components/layout/BaseLayout.astro';
import AppearancesList from '../components/about/AppearancesList.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import Markdoc from '@markdoc/markdoc';

const reader = createReader(process.cwd(), keystaticConfig);
const about = await reader.singletons.about.read();

// content field is a ContentFormField: ValueForReading is () => Promise<{ node }>
const contentResult = about?.content ? await about.content() : null;
const contentHtml = contentResult
  ? Markdoc.renderers.html(Markdoc.transform(contentResult.node))
  : '';
---

<BaseLayout
  title="About — Ryan McGovern"
  description={about?.metaDescription ?? 'About Ryan McGovern — developer and community builder.'}
>
  <main class="about-page">
    <div class="about-inner">
      <header class="about-header">
        <h1 class="about-heading">About</h1>
      </header>

      {contentHtml && (
        <article class="prose about-prose" set:html={contentHtml} />
      )}

      <AppearancesList />
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    padding: 3rem 1.5rem 4rem;
  }

  .about-inner {
    max-width: var(--prose-width);
    margin: 0 auto;
  }

  .about-header {
    margin-bottom: 2rem;
    border-bottom: var(--border-width) solid var(--border);
    padding-bottom: 1.25rem;
  }

  .about-heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1;
  }

  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4),
  .prose :global(h5),
  .prose :global(h6) {
    font-family: var(--font-heading);
    line-height: var(--line-height-heading);
    margin: 1.75em 0 0.6em;
    color: var(--text);
  }

  .prose :global(h2) { font-size: 1.6rem; }
  .prose :global(h3) { font-size: 1.3rem; }

  .prose :global(p) {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: var(--line-height-body);
    color: var(--text);
    margin: 0 0 1.25em;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25em 1.5rem;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: var(--line-height-body);
  }

  .prose :global(li) {
    margin-bottom: 0.375em;
  }

  .prose :global(a) {
    color: var(--accent-secondary);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .prose :global(a:hover) {
    color: var(--accent-primary);
  }

  .prose :global(blockquote) {
    border-left: var(--border-width) solid var(--accent-primary);
    margin: 1.5em 0;
    padding: 0.75em 1.25em;
    background-color: var(--surface);
    border: var(--border-width) solid var(--border);
    box-shadow: var(--shadow);
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background-color: var(--muted);
    padding: 0.15em 0.4em;
  }

  .prose :global(hr) {
    border: none;
    border-top: var(--border-width) solid var(--border);
    margin: 2.5em 0;
  }
</style>
